# Copy this file to ".env.e2e" and fill real values
E2E_API_URL=http://127.0.0.1:5000/api
E2E_EMAIL=your-login-email
E2E_PASSWORD=your-login-password
E2E_SHOP_ID=your-unique-shop-id

# Optional fixed ids (leave blank to auto-resolve from dropdown endpoints)
E2E_BRANCH_ID=
E2E_CATEGORY_ID=
E2E_UNIT_ID=
